      "@id": "#input-tx2gene",
      "@type": "FormalParameter",
      "description": "Transcript-to-gene mapping table (3 columns: tx_id, gene_id, gene_name)",
      "encodingFormat": "text/tab-separated-values",
      "name": "tx2gene.tsv"
    },
    {
      "@id": "#input-metadata",
      "@type": "FormalParameter",
      "description": "Sample metadata CSV with columns: sample, file, and group column",
      "encodingFormat": "text/csv",
      "name": "metadata.csv"
    },
    {
      "@id": "#input-salmon-quant",
      "@type": "FormalParameter",
      "description": "Per-sample Salmon quantification output (quant.sf)",
      "encodingFormat": "text/tab-separated-values",
      "name": "Salmon quant.sf files"
    },
    {
      "@id": "#input-gmt",
      "@type": "FormalParameter",
      "description": "MSigDB Hallmark gene-set GMT file for mouse or human (optional)",
      "encodingFormat": "text/plain",
      "name": "Hallmark gene-set GMT (optional)"
    },
    {
      "@id": "#output-deg-xlsx",
      "@type": "FormalParameter",
      "description": "Per-comparison DEG results with log2FC, padj, and column descriptions",
      "encodingFormat": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "name": "DEG Excel tables"
    },
    {
      "@id": "#output-tpm-csv",
      "@type": "FormalParameter",
      "encodingFormat": "text/csv",
